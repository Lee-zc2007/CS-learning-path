#include <iostream>
using namespace std;

const int MAXN = 5005;

//统计入度和出度，法官满足出度为0，入度为n-1
int inDeg[MAXN];
int outDeg[MAXN];
bool vis[MAXN][MAXN];

int main() {
    int n, m;
    cin >> n >> m;

    for (int i = 1; i <= n; i++) {
        inDeg[i] = 0;
        outDeg[i] = 0;
    }

    for (int i = 0; i < m; i++) {
        int a, b;
        cin >> a >> b;

        // 如果这条边已经出现过，就不重复统计
        if (vis[a][b] == false) {
            vis[a][b] = true;
            outDeg[a]++;
            inDeg[b]++;
        }
    }

    int judge = -1;
    int cnt = 0;

    for (int i = 1; i <= n; i++) {
        if (outDeg[i] == 0 && inDeg[i] == n - 1) {
            judge = i;
            cnt++;
        }
    }

    if (cnt == 1) {
        cout << judge << endl;
    } else {
        cout << -1 << endl;
    }

    return 0;
}